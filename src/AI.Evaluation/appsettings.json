{
  "KernelSettings": {
    "serviceType": "",
    "serviceId": "",
    "modelId": "",
    "apiKey": "",
    "orgId": "",
    "endpoint": ""
  },
  "AppSettings": {
    "ChatType": "ChatSession"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}
